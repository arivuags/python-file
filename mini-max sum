def miniMaxSum(arr):
    # Calculate the total sum of all 5 elements
    total_sum = sum(arr)
    
    # Minimum sum: total minus the largest element
    min_sum = total_sum - max(arr)
    
    # Maximum sum: total minus the smallest element
    max_sum = total_sum - min(arr)
    
    print(f"{min_sum} {max_sum}")

if __name__ == '__main__':
    arr = list(map(int, input().rstrip().split()))
    miniMaxSum(arr)
