import re

def transform(match):
    if match.group(0) == '&&':
        return 'and'
    return 'or'

# Read number of lines
n = int(input())

for _ in range(n):
    line = input()
    
    # (?<= ) checks for a space before
    # (?= ) checks for a space after
    # We do this twice to handle overlapping or consecutive matches
    line = re.sub(r"(?<= )(&&|\|\|)(?= )", transform, line)
    line = re.sub(r"(?<= )(&&|\|\|)(?= )", transform, line)
    
    print(line)
